{
  "name": "flarestatus",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    ".",
    "probe"
  ],
  "scripts": {
    "build": "bun build src/server.ts --outdir dist --target bun",
    "dev": "bun run src/server.ts",
    "migrate": "bun run scripts/migrate.ts",
    "start": "bun run src/server.ts",
    "test": "bun vitest run",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
