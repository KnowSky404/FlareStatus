# Core app exposure
APP_PORT=3000

# Core database
POSTGRES_DB=flarestatus
POSTGRES_USER=flarestatus
POSTGRES_PASSWORD=flarestatus

# Core API auth
ADMIN_API_TOKEN=change-me-admin-token
PROBE_API_TOKEN=change-me-probe-token

# Optional bundled probe
# Enable with:
# docker compose -f docker-compose.yml -f docker-compose.probe.yml up -d --build
PROBE_COMPONENT_SLUG=flarestatus-public-api
PROBE_REPORT_ENDPOINT=http://app:3000/api/probe/report
PROBE_REPORT_TOKEN=change-me-probe-token

# Optional bundled probe runtime
PROBE_INTERVAL_MS=30000
PROBE_RUN_ONCE=false
PROBE_CHECK_TYPE=http

# Optional bundled probe HTTP check
PROBE_HTTP_URL=http://app:3000/api/public/status
PROBE_HTTP_TIMEOUT_MS=3000
PROBE_HTTP_EXPECTED_STATUS=200
